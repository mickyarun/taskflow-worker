#!/bin/sh
# installed-by-bodhiorchard (pre-commit)
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
BUD_NUM=$(echo "$BRANCH" | sed -n 's/^bud-\([0-9]*\)\/.*/\1/p')
[ -z "$BUD_NUM" ] && exit 0

STATUS=$(curl -s -o /dev/null -w "%{http_code}" \
  "https://backendchat.ngrok.app/api/v1/public/fbd235d6-25b9-4130-af65-d295b741693c/bud-check/$BUD_NUM" 2>/dev/null)
if [ "$STATUS" = "404" ]; then
  echo "BUD-$BUD_NUM not found in Bodhiorchard. Commit blocked."
  exit 1
fi
